    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,html}\"",
    "preview": "vite preview"
  },
  "dependencies": {
